<?xml version="1.0" encoding="utf-8"?>
<!-- FULLY FIXED URDF
     Changes vs original:
     1. dummy_joint has NO rpy (geometry is already Z-up)
     2. ALL inertial origins set to actual CoM from STL bounding box centroids
     3. lidar_link given dummy mass/inertia (was zero -> NaN)
     4. left/right wheel mass 7.99->0.5kg, inertia from real dimensions
     5. Gazebo friction tags added
     Spawn this robot at z=-0.455 in your launch file.
-->
<robot name="alpha_bot">

  <link name="dummy_link"/>

  <joint name="dummy_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="dummy_link"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="11.87"/>
      <inertia ixx="0.23942" ixy="0" ixz="0.0018807" iyy="0.42955" iyz="0" izz="0.28243"/>
    </inertial>
    <visual>
      <!-- Shift mesh so robot body is centered on base_link origin -->
      <origin xyz="-0.2691 0.6850 -0.6936" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.2691 0.6850 -0.6936" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <inertial>
      <origin xyz="0.0000 0.0444 0.0000" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.005582" ixy="0" ixz="0" iyy="0.010506" iyz="0" izz="0.005582"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/left_wheel.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.64706 0.61961 0.58824 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/left_wheel.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <!-- Original: (0.26914, -0.37359, 0.67469) minus CoM offset (0.2691, -0.685, 0.6936) -->
    <origin xyz="0.00004 0.31141 -0.01891" rpy="3.1416 -0.42108 0"/>
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <inertial>
      <origin xyz="0.0000 -0.0444 0.0000" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.005582" ixy="0" ixz="0" iyy="0.010506" iyz="0" izz="0.005582"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/right_wheel.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.64706 0.61961 0.58824 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/right_wheel.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <!-- Original: (0.26915, -0.90749, 0.67469) minus CoM offset (0.2691, -0.685, 0.6936) -->
    <origin xyz="0.00005 -0.22249 -0.01891" rpy="-3.1416 1.5448 -3.1416"/>
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="back_castor">
    <inertial>
      <origin xyz="-0.0000 0.0075 -0.0305" rpy="0 0 0"/>
      <mass value="0.016198"/>
      <inertia ixx="9.6663e-06" ixy="0" ixz="0" iyy="1.2353e-05" iyz="0" izz="1.4421e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/back_castor.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/back_castor.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="back_castor_joint" type="continuous">
    <!-- Original: (-0.10911, -0.68499, 0.49599) minus CoM offset (0.2691, -0.685, 0.6936) -->
    <origin xyz="-0.37821 0.00001 -0.19761" rpy="-3.1416 0 -2.6028"/>
    <parent link="base_link"/>
    <child link="back_castor"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="back_wheel">
    <inertial>
      <origin xyz="0.0000 0.0015 0.0000" rpy="0 0 0"/>
      <mass value="0.10036"/>
      <inertia ixx="3.4167e-05" ixy="0" ixz="0" iyy="5.2134e-05" iyz="0" izz="3.4167e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/back_wheel.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/back_wheel.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="back_wheel_joint" type="continuous">
    <origin xyz="0 0.030947 -0.0125" rpy="0 1.2749 -1.5708"/>
    <parent link="back_castor"/>
    <child link="back_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_castor">
    <inertial>
      <origin xyz="-0.0000 0.0075 -0.0305" rpy="0 0 0"/>
      <mass value="0.016198"/>
      <inertia ixx="9.6663e-06" ixy="0" ixz="0" iyy="1.2353e-05" iyz="0" izz="1.4421e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/front_castor.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/front_castor.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_castor_joint" type="continuous">
    <!-- Original: (0.64739, -0.68499, 0.49599) minus CoM offset (0.2691, -0.685, 0.6936) -->
    <origin xyz="0.37829 0.00001 -0.19761" rpy="3.1416 0 1.1185"/>
    <parent link="base_link"/>
    <child link="front_castor"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="front_wheel">
    <inertial>
      <origin xyz="0.0000 0.0012 0.0000" rpy="0 0 0"/>
      <mass value="0.10036"/>
      <inertia ixx="3.4167e-05" ixy="0" ixz="0" iyy="5.2134e-05" iyz="0" izz="3.4167e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/front_wheel.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/front_wheel.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_wheel_joint" type="continuous">
    <origin xyz="0 0.030947 -0.0125" rpy="0 0.22579 -1.5708"/>
    <parent link="front_castor"/>
    <child link="front_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <origin xyz="0.4253 -0.3091 -0.0845" rpy="0 0 0"/>
      <mass value="0.14725"/>
      <inertia ixx="0.00028228" ixy="0" ixz="0" iyy="9.3322e-05" iyz="0" izz="0.00023677"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/camera_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/camera_link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <!-- Original: (0.27827, -0.37359, 0.67877) minus CoM offset (0.2691, -0.685, 0.6936) -->
    <origin xyz="0.00917 0.31141 -0.01483" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0.0000 0.0206 -0.0046" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/lidar_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/naveen/alpha_bot/src/alpha_bot/meshes/lidar_link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <!-- Original: (0.68427, -0.68284, 0.89099) minus CoM offset (0.2691, -0.685, 0.6936) -->
    <origin xyz="0.41517 0.00216 0.19739" rpy="1.5708 0 1.5708"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <axis xyz="0 0 0"/>
  </joint>




  <!-- Differential drive plugin — receives /cmd_vel, drives left/right wheels -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.6264</wheel_separation>  <!-- left axle y=+0.31141, right axle y=-0.31500 → 0.6264m -->
      <wheel_radius>0.205</wheel_radius>            <!-- from STL: wheel Z extents = 0.41m → radius = 0.205m -->
      <odom_publish_frequency>10</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

</robot>
